generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Regiment {
  id        Int       @id @default(autoincrement())
  name      String
  companies Company[]
}

model Company {
  id         Int       @id @default(autoincrement())
  name       String
  regimentId Int
  regiment   Regiment  @relation(fields: [regimentId], references: [id])
  sections   Section[]

  @@index([regimentId])
}

model Section {
  id        String    @id
  name      String
  companyId Int
  company   Company   @relation(fields: [companyId], references: [id])
  soldiers  Soldier[]
  announcements Announcement[]

  @@index([companyId])
}

model Soldier {
  id        String  @id
  name      String
  fullName  String
  rank      String
  photo     String
  commandCategory CommandCategory @default(MILITAIRE_DU_RANG)
  sectionId String
  section   Section @relation(fields: [sectionId], references: [id])
  createdById String?
  createdBy   User? @relation("CreatedBy", fields: [createdById], references: [id])
  issuedCredentials IssuedCredential[]

  @@index([sectionId])
  @@index([createdById])
}

model User {
  id            String         @id @default(uuid())
  username      String?        @unique
  email         String?        @unique
  passwordHash  String
  role          UserRole       @default(VIEWER)
  isActive      Boolean        @default(true)
  mustChangePassword Boolean   @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]
  createdSoldiers Soldier[]    @relation("CreatedBy")
  createdCredentials IssuedCredential[] @relation("CredentialCreatedBy")
  issuedCredentials IssuedCredential[] @relation("CredentialForUser")
  createdAnnouncements Announcement[] @relation("AnnouncementCreatedBy")
  announcementReads AnnouncementRead[]
}

model Announcement {
  id          String   @id @default(uuid())
  title       String
  body        String
  scope       VisibilityScope @default(COMPANY)
  sectionId   String?
  section     Section? @relation(fields: [sectionId], references: [id])
  isPinned    Boolean  @default(false)
  isUrgent    Boolean  @default(false)
  isArchived  Boolean  @default(false)
  expiresAt   DateTime?
  createdById String
  createdBy   User     @relation("AnnouncementCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  reads       AnnouncementRead[]

  @@index([sectionId])
  @@index([scope, isArchived, expiresAt])
  @@index([createdAt])
}

model AnnouncementRead {
  id             String   @id @default(uuid())
  announcementId String
  userId         String
  readAt         DateTime @default(now())
  announcement   Announcement @relation(fields: [announcementId], references: [id])
  user           User         @relation(fields: [userId], references: [id])

  @@unique([announcementId, userId])
  @@index([userId, readAt])
}

model IssuedCredential {
  id                     String   @id @default(uuid())
  userId                 String
  soldierId              String
  usernameSnapshot       String
  encryptedTempPassword  String
  createdById            String
  createdAt              DateTime @default(now())
  passwordChangedAt      DateTime?
  lastViewedAt           DateTime?

  user                   User     @relation("CredentialForUser", fields: [userId], references: [id])
  soldier                Soldier  @relation(fields: [soldierId], references: [id])
  createdBy              User     @relation("CredentialCreatedBy", fields: [createdById], references: [id])

  @@index([createdById])
  @@index([userId])
  @@index([soldierId])
  @@index([createdAt])
}

model RefreshToken {
  id         String    @id @default(uuid())
  tokenHash  String    @unique
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  entity    String
  entityId  String?
  details   Json?
  actorId   String
  actor     User     @relation(fields: [actorId], references: [id])
  createdAt DateTime @default(now())

  @@index([actorId])
}

enum UserRole {
  ADMIN
  MANAGER
  VIEWER
}

enum CommandCategory {
  CHEF_DE_SECTION
  SOUS_OFFICIER_ADJOINT
  SERGENT
  MILITAIRE_DU_RANG
}

enum VisibilityScope {
  REGIMENT
  COMPANY
  SECTION
}
