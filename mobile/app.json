{
  "expo": {
    "name": "Unit Directory",
    "slug": "unit-directory",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0d120f"
    },
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSUserNotificationUsageDescription": "Cette application envoie des notifications pour les nouvelles annonces de l'unité."
      },
      "bundleIdentifier": "com.anonymous.unit-directory"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0d120f"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-asset",
      "expo-secure-store",
      "expo-notifications"
    ]
  }
}
